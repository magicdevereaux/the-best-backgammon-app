{
  "expo": {
    "name": "The Best Backgammon App",
    "slug": "the-best-backgammon-app",
    "scheme": "backgammon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F1A12",
    "primaryColor": "#C8952A",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.magicdevereaux.backgammon",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.magicdevereaux.backgammon",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0F1A12",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F1A12",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
